{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":separateMajorReleases",
    ":combinePatchMinorReleases",
    ":semanticPrefixFixDepsChoreOthers"
  ],
  "timezone": "America/Lima",
  "schedule": [
    "before 5am on saturday"
  ],
  "github-actions": {
    "enabled": true
  },
  "packageRules": [
    {
      "description": "Group all development dependencies together",
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["patch", "minor"],
      "groupName": "Development dependencies (non-major)"
    },
    {
      "description": "Group Electron updates into a single Pull Request",
      "matchPackagePatterns": ["^electron"],
      "groupName": "Electron updates"
    },
    {
      "description": "Automerge minor and patch updates for non-critical tools",
      "matchPackagePatterns": ["eslint", "playwright", "@playwright/test", "globals"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    }
  ]
}
